{
  "name": "immich-frame",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "generate": "python3 scripts/generate_assets.py",
    "check:generated": "python3 scripts/generate_assets.py --check",
    "check:firmware-release": "python3 scripts/check_firmware_release.py",
    "check:release-changelog": "python3 scripts/check_release_changelog.py",
    "check:product": "python3 scripts/check_product_contract.py",
    "changelog:release": "python3 scripts/release_changelog.py",
    "test:timezones": "python3 scripts/check_timezones.py",
    "test:helpers": "g++ -std=c++17 -I. -Itests/stubs tests/espframe_helper_tests.cpp -o /tmp/espframe_helper_tests && /tmp/espframe_helper_tests",
    "check:all": "npm run check:generated && npm run check:product && npm run test:timezones && npm run test:helpers && npm run check:firmware-release && npm run check:release-changelog && npm run docs:build",
    "webserver:build": "python3 scripts/generate_assets.py",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "vitepress": "^1.6.3"
  }
}
