      "max": 23,
      "step": 1,
      "firmware_files": ["common/addon/backlight_schedule.yaml"],
      "docs_files": ["docs/screen-settings.md"]
    },
    {
      "key": "schedule_off_hour",
      "entity": { "domain": "number", "name": "Screen: Schedule Off Hour" },
      "default": 23,
      "docs_label": "Off Time",
      "docs_description": "Backlight off (hour)",
      "min": 0,
      "max": 23,
      "step": 1,
      "firmware_files": ["common/addon/backlight_schedule.yaml"],
      "docs_files": ["docs/screen-settings.md"]
